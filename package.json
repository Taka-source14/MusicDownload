{
  "name": "altaysound-bot",
  "version": "1.0.0",
  "description": "A simple Discord bot that plays a song 24/7 in a voice channel.",
  "main": "download.js",
  "scripts": {
    "start": "node download.js",
    "download": "node download.js",
    "build": "pkg . --out-path dist"
  },
  "bin": "download.js",
  "pkg": {
    "assets": [
      "README.md",
      "LICENSE",
      "public/**/*",
      "yt-dlp.exe",
      "node_modules/ffmpeg-static/ffmpeg.exe",
      "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe"
    ],
    "targets": [
      "node18-win-x64"
    ]
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}